</div>
</div>
<!-- Timeline Item -->
<div class="flex gap-4 relative">
<div class="flex flex-col items-center">
<div class="size-3 rounded-full bg-primary z-10"></div>
<div class="w-px h-full bg-slate-200 dark:border-slate-800 absolute top-3"></div>
</div>
<div class="pb-6">
<p class="text-sm font-bold">Security Checks Passed</p>
<p class="text-xs text-slate-500 mt-1">Today, 09:38 AM • AI Guard</p>
</div>
</div>
<!-- Timeline Item -->
<div class="flex gap-4 relative">
<div class="flex flex-col items-center">
<div class="size-3 rounded-full bg-slate-300 dark:bg-slate-700 z-10"></div>
</div>
<div>
<p class="text-sm font-bold">Request Initiated</p>
<p class="text-xs text-slate-500 mt-1">Today, 09:30 AM • Mobile App</p>
</div>
</div>
</div>
</section>
<!-- Administrative Remarks -->
<section class="mt-10">
<div class="flex items-center gap-2 px-1 mb-4">
<span class="material-symbols-outlined text-primary text-xl">edit_note</span>
<h3 class="text-lg font-bold tracking-tight">Administrative Remarks</h3>
</div>
<textarea class="w-full bg-white dark:bg-card-dark border border-slate-200 dark:border-slate-800 rounded-xl p-4 focus:ring-2 focus:ring-primary focus:border-transparent transition-all outline-none text-sm" placeholder="Enter internal notes regarding this withdrawal process..." rows="4"></textarea>
</section>
</main>
<!-- Fixed Action Footer -->
<footer class="fixed bottom-0 left-0 right-0 p-6 bg-background-light/90 dark:bg-background-dark/90 backdrop-blur-xl border-t border-slate-200 dark:border-slate-800 z-50">
<div class="max-w-xl mx-auto">
<button class="w-full bg-primary hover:bg-primary/90 text-white font-bold py-5 rounded-xl transition-all glow-subtle flex items-center justify-center gap-2 group active:scale-[0.98]">
<span class="material-symbols-outlined group-hover:rotate-12 transition-transform">check_circle</span>
                Complete Process
            </button>
</div>
</footer>
