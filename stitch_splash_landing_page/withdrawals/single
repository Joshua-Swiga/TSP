</div>
<div class="absolute bottom-1 right-1 bg-green-500 size-5 rounded-full border-4 border-background-dark"></div>
</div>
<div class="text-center">
<h2 class="text-3xl font-bold tracking-tight">Alex Thompson</h2>
<p class="text-slate-500 dark:text-slate-400 font-medium mt-1">+1 (555) 012-3456</p>
<div class="mt-6 px-6 py-2 rounded-full bg-primary/10 border border-primary/20 inline-block">
<span class="text-xs uppercase tracking-widest text-primary font-bold dark:text-blue-400">Available Balance</span>
<p class="text-2xl font-bold mt-1">$24,500.00</p>
</div>
</div>
</header>
<!-- Account Stats -->
<section class="mt-8">
<div class="flex items-center gap-2 px-1 mb-4">
<span class="material-symbols-outlined text-primary text-xl">account_balance_wallet</span>
<h3 class="text-lg font-bold tracking-tight">Account Stats</h3>
</div>
<div class="grid grid-cols-2 gap-4">
<div class="bg-white dark:bg-card-dark p-6 rounded-xl border border-slate-200 dark:border-slate-800 flex flex-col gap-1">
<p class="text-xs font-bold text-slate-400 uppercase tracking-wider">Requested</p>
<p class="text-xl font-bold">$12,450.00</p>
</div>
<div class="bg-white dark:bg-card-dark p-6 rounded-xl border border-slate-200 dark:border-slate-800 flex flex-col gap-1">
