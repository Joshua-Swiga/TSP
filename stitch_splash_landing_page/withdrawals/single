<p class="text-xl font-bold text-red-500">$12.50</p>
</div>
</div>
</section>
<!-- Technical Meta Data -->
<section class="mt-10">
<div class="flex items-center gap-2 px-1 mb-4">
<span class="material-symbols-outlined text-primary text-xl">terminal</span>
